    <File>BCY/Database/10_config_values.sql</File>
    <File>BCY/Database/11_core_rules.sql</File>
    <File>BCY/Database/12_no_rng_rules.sql</File>
    <File>BCY/Database/13_runtime_support.sql</File>
    <File>BCY/Database/14_capital_only.sql</File>
    <File>BCY/Scripts/bcy_lookup.lua</File>
