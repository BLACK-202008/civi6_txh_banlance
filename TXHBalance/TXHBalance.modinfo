    <File>Scripts/txh_bcy_bridge.xml</File>
    <File>Scripts/txh_bcy_bridge.lua</File>
    <File>TXHBalance_Units.dep</File>
    <File>ArtDefs/Units.artdef</File>
  </Files>
</Mod>
